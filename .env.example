# Copy to .env and fill in real values. .env is git-ignored — never commit it.

# Optional — defaults to https://api.matchbook.com if unset.
MATCHBOOK_BASE_URL=https://api.matchbook.com

# Required — the shared test account. See CLAUDE.md for lockout constraints.
MATCHBOOK_USERNAME=
MATCHBOOK_PASSWORD=

# Cross-process rate limiter (ADR-004) — enforced at the HTTP transport
# layer so every request, from every test/worker, respects one shared
# budget. Optional — defaults shown below; disable only for a mocked/local
# target that has no real rate limit to respect.
RATE_LIMIT_ENABLED=true
# Requests per minute, shared across all pytest-xdist workers. Deliberately
# below the documented 25/minute IP-block threshold: the real API's
# Cloudflare layer enforces a stricter burst limit than the account-level
# rule, so this also caps how close together requests can land.
RATE_LIMIT_MAX_PER_MINUTE=20